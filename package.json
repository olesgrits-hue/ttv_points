{
  "name": "ttweaks",
  "version": "1.1.1",
  "description": "Portable Electron app — Twitch Channel Points media overlay + Yandex Music integration",
  "main": "dist/main/index.js",
  "author": "Twitch Helper Dev",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:main && npm run build:renderer && electron-builder --win portable --config electron-builder.config.js",
    "package": "electron-builder --win portable --config electron-builder.config.js --publish never",
    "postinstall": "echo skipped native rebuild",
    "test": "jest --passWithNoTests",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,html,css,json}\""
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^4.21.1",
    "keytar": "7.9.0",
    "pkce-challenge": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "to-ico": "^1.1.5",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
