{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist/main",
    "rootDir": "src/main",
    "lib": ["ES2022"],
    "types": ["node"],
    "jsx": "preserve"
  },
  "include": ["src/main/**/*"],
  "exclude": ["node_modules", "dist", "build", "src/renderer", "src/overlay", "tests"]
}
